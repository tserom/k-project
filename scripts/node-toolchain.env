# Node 工具链版本 —— 仅用于 vendor/ 老组件库（sula、business-component 等）
# k-project 业务应用（apps/*）一律 Node 20.19.x + pnpm，见 docs/WORKSPACE.md 与 scripts/README.md
# 修改后重新运行: bash scripts/setup-node-toolchain.sh

# nvm 本身
NVM_VERSION=0.39.7

# Node / npm（npm 随 Node 安装后再 pin 到指定版本）
NODE_VERSION=16.20.0
NPM_VERSION=8.17.0

# 全局 CLI（cnpm 会捆绑对应版本的 npminstall）
CNPM_VERSION=8.3.0
NPMINSTALL_VERSION=6.5.0

# nvm 默认 alias（新开终端自动使用的 Node）
NVM_DEFAULT_ALIAS=16

# cnpm 镜像（与当前开发机一致）
CNPM_REGISTRY=https://registry.npmmirror.com/
CNPM_DISTURL=https://npmmirror.com/mirrors/node
